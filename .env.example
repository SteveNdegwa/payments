ENV=local
DEBUG=1
ALLOWED_HOSTS=*
SECRET_KEY=replace-me
APP_PATH=/var/www/payments

CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//

# Postgres. Leave DATABASE_DB unset to fall back to local sqlite.
DATABASE_DB=payments
DATABASE_USER=payments
DATABASE_PASSWORD=payments
DATABASE_HOST=localhost
DATABASE_PORT=5432
